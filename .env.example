# Google OAuth client ID (Web application) for "Export to Google Slides".
# See README → Google Slides export for GCP setup steps.
#
# Option A — local file (gitignored):
#   cp .env.example .env
#   paste your client ID below, then: npm run dev
#
# Option B — 1Password (recommended for multiple machines):
#   npm run setup:op   # once, after enabling 1Password CLI + desktop integration
#   npm run dev:op
VITE_GOOGLE_CLIENT_ID=
